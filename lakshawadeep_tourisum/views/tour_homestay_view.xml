<odoo>

    <!-- FORM VIEW -->

    <record id="view_homestay_form" model="ir.ui.view">
        <field name="name">tour.homestay.form</field>
        <field name="model">tour.homestay</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>


                    <group>
                        <group>
                            <field name="name"/>
                            <field name="island_id"/>
                            <field name="vendor_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                        </group>

                        <group>

                            <field name="price_per_night"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <field name="description"/>

                    <notebook>

                        <page string="Bookings">

                            <field name="booking_ids">

                                <list>
                                    <field name="booking_no"/>
                                    <field name="customer_id"/>
                                    <field name="checkin_date"/>
                                    <field name="room_count"/>
                                    <field name="amount"/>
                                    <field name="state"/>
                                </list>

                                <form>
                                    <sheet>
                                        <group>
                                            <field name="booking_no" readonly="1"/>
                                            <field name="customer_id"/>
                                            <field name="checkin_date"/>
                                            <field name="room_count"/>
                                            <field name="amount"/>
                                            <field name="state"/>
                                        </group>
                                    </sheet>
                                </form>

                            </field>

                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->

    <record id="view_homestay_list" model="ir.ui.view">
        <field name="name">tour.homestay.list</field>
        <field name="model">tour.homestay</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="price_per_night"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- KANBAN VIEW -->

    <record id="view_homestay_kanban" model="ir.ui.view">
        <field name="name">tour.homestay.kanban</field>
        <field name="model">tour.homestay</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="name"/>
                <field name="image"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="price_per_night"/>

                <templates>
                    <t t-name="card" class="flex-row">

                        <aside class="o_kanban_aside_full">
                            <field name="image"
                                   widget="background_image"
                                   class="d-block position-relative"/>
                        </aside>

                        <main class="ms-2">

                            <div class="fw-bold fs-5">
                                <field name="name"/>
                            </div>

                            <div>
                                <i class="fa fa-map-marker me-2"/>
                                <field name="island_id"/>
                            </div>

                            <div>
                                <i class="fa fa-building me-2"/>
                                <field name="vendor_id"/>
                            </div>

                            <div>
                                <i class="fa fa-money me-2"/>
                                ₹
                                <field name="price_per_night"/>
                                / Night
                            </div>

                        </main>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- BOOKING SEQUENCE -->

    <record id="seq_homestay_booking" model="ir.sequence">
        <field name="name">Homestay Booking</field>
        <field name="code">tour.homestay.booking</field>
        <field name="prefix">HSB/</field>
        <field name="padding">5</field>
    </record>

    <!-- ACTION -->

    <record id="action_homestay" model="ir.actions.act_window">
        <field name="name">Homestays</field>
        <field name="res_model">tour.homestay</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- MENU -->

    <menuitem id="menu_homestay"
              name="Homestays"
              action="action_homestay"
              sequence="40"/>

</odoo>