<odoo>

    <!-- ===================================================== --> <!-- TAXI SEARCH VIEW --> <!-- ===================================================== -->
    <record id="view_tour_taxi_search" model="ir.ui.view">
        <field name="name">tour.taxi.search</field>
        <field name="model">tour.taxi</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="vehicle_type"/>
                <filter name="active_filter" string="Active" domain="[('active','=',True)]"/>

                <filter name="agatti"
                        string="Agatti"
                        domain="[('island_id.name','=','Agatti')]"/>

                <filter name="kavaratti"
                        string="Kavaratti"
                        domain="[('island_id.name','=','Kavaratti')]"/>

                <filter name="kalpeni"
                        string="Kalpeni"
                        domain="[('island_id.name','=','Kalpeni')]"/>

                <filter name="kadamath"
                        string="Kadamath"
                        domain="[('island_id.name','=','Kadamath')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_island" string="Island" context="{'group_by':'island_id'}"/>
                    <filter name="group_vendor" string="Vendor" context="{'group_by':'vendor_id'}"/>
                    <filter name="group_vehicle" string="Vehicle Type" context="{'group_by':'vehicle_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- FORM -->

    <record id="view_taxi_form" model="ir.ui.view">
        <field name="name">tour.taxi.form</field>
        <field name="model">tour.taxi</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <field name="image"
                           widget="image"
                           class="oe_avatar"/>

                    <group>
                        <group>
                            <field name="name"/>

                            <field name="island_id"/>

                            <field name="vendor_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>

                            <field name="vehicle_type"/>

                            <field name="active"/>
                        </group>

                        <group>
                            <field name="seater"/>

                            <field name="ac"/>
                            <field name="feature_ids"
                                   widget="many2many_tags"/>

                        </group>
                    </group>

                    <notebook>

                        <page string="Description">

                            <field name="description"
                                   placeholder="Taxi description..."/>

                        </page>

                        <page string="Bookings">

                            <field name="booking_ids" readonly="1">

                                <list>
                                    <field name="customer_id"/>
                                    <field name="booking_date"/>
                                    <field name="pickup_location"/>
                                    <field name="drop_location"/>
                                    <field name="passengers"/>
                                </list>

                                <form>
                                    <sheet>
                                        <group>

                                            <field name="customer_id"/>

                                            <field name="booking_date"/>

                                            <field name="pickup_location"/>

                                            <field name="drop_location"/>

                                            <field name="passengers"/>

                                            <field name="description"/>

                                        </group>
                                    </sheet>
                                </form>

                            </field>

                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>
    <!-- LIST -->

    <record id="view_tour_taxi_list" model="ir.ui.view">
        <field name="name">tour.taxi.list</field>
        <field name="model">tour.taxi</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="vehicle_type"/>
                <field name="seater"/>
                <field name="ac"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- KANBAN -->

    <record id="view_tour_taxi_kanban" model="ir.ui.view">
        <field name="name">tour.taxi.kanban</field>
        <field name="model">tour.taxi</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="name"/>
                <field name="image"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="vehicle_type"/>
                <field name="seater"/>

                <templates>
                    <t t-name="card" class="flex-row">

                        <aside class="o_kanban_aside_full">
                            <field name="image"
                                   widget="background_image"
                                   class="d-block position-relative"/>
                        </aside>

                        <main class="ms-2">

                            <div class="fw-bold fs-5">
                                <field name="name"/>
                            </div>

                            <div>
                                <i class="fa fa-map-marker me-2"/>
                                <field name="island_id"/>
                            </div>

                            <div>
                                <i class="fa fa-building me-2"/>
                                <field name="vendor_id"/>
                            </div>

                            <div>
                                <i class="fa fa-car me-2"/>
                                <field name="vehicle_type"/>
                            </div>

                            <div>
                                <i class="fa fa-users me-2"/>
                                <field name="seater"/>
                                Seats
                            </div>

                        </main>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>



    <!-- ACTION -->

    <record id="action_tour_taxi" model="ir.actions.act_window">
        <field name="name">Taxi Services</field>
        <field name="res_model">tour.taxi</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_tour_taxi_search"/>
    </record>

    <!-- MENU -->

    <menuitem id="menu_tour_taxi"
              name="Taxi Services"
              action="action_tour_taxi"
              sequence="50"/>

</odoo>