<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- SEARCH VIEW -->

    <record id="view_taxi_booking_search" model="ir.ui.view">
        <field name="name">tour.taxi.booking.search</field>
        <field name="model">tour.taxi.booking</field>
        <field name="arch" type="xml">
            <search>

                <field name="taxi_id"/>
                <field name="customer_id"/>

                <filter name="draft"
                        string="Draft"
                        domain="[('state','=','draft')]"/>

                <filter name="confirmed"
                        string="Confirmed"
                        domain="[('state','=','confirmed')]"/>

                <filter name="cancelled"
                        string="Cancelled"
                        domain="[('state','=','cancelled')]"/>

                <group expand="0" string="Group By">

                    <filter name="group_taxi"
                            string="Taxi"
                            context="{'group_by':'taxi_id'}"/>

                    <filter name="group_customer"
                            string="Customer"
                            context="{'group_by':'customer_id'}"/>

                    <filter name="group_state"
                            string="Status"
                            context="{'group_by':'state'}"/>

                </group>

            </search>
        </field>
    </record>

    <!-- LIST VIEW -->

    <record id="view_taxi_booking_list" model="ir.ui.view">
        <field name="name">tour.taxi.booking.list</field>
        <field name="model">tour.taxi.booking</field>
        <field name="arch" type="xml">
            <list>

                <field name="booking_date"/>

                <field name="taxi_id"/>

                <field name="customer_id"/>

                <field name="pickup_location"/>

                <field name="drop_location"/>

                <field name="passengers"/>

                <field name="state"/>

            </list>
        </field>
    </record>

    <!-- FORM VIEW -->

    <record id="view_taxi_booking_form" model="ir.ui.view">
        <field name="name">tour.taxi.booking.form</field>
        <field name="model">tour.taxi.booking</field>
        <field name="arch" type="xml">

            <form>

                <header>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirmed,cancelled"/>

                </header>

                <sheet>

                    <group>

                        <group>

                            <field name="taxi_id"/>

                            <field name="customer_id"/>

                            <field name="booking_date"/>

                        </group>

                        <group>

                            <field name="pickup_location"/>

                            <field name="drop_location"/>

                            <field name="passengers"/>

                        </group>

                    </group>

                    <group>

                        <field name="description"/>

                    </group>

                </sheet>

            </form>

        </field>
    </record>

    <!-- ACTION -->

    <record id="action_taxi_booking"
            model="ir.actions.act_window">

        <field name="name">Taxi Bookings</field>

        <field name="res_model">tour.taxi.booking</field>

        <field name="view_mode">list,form</field>

        <field name="search_view_id"
               ref="view_taxi_booking_search"/>

    </record>

    <!-- MENU -->

    <menuitem id="menu_taxi_booking"
              name="Bookings"
              parent="menu_tour_taxi"
              action="action_taxi_booking"
              sequence="60"/>

</odoo>
