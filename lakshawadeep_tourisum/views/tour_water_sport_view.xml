<odoo>

    <record id="view_water_sport_form" model="ir.ui.view">
        <field name="name">tour.water.sport.form</field>
        <field name="model">tour.water.sport</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <field name="image"
                           widget="image"
                           class="oe_avatar"/>

                    <group>
                        <group>
                            <field name="name"/>

                            <field name="island_id"/>

                            <field name="vendor_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>

                            <field name="active"/>
                        </group>

                        <group>
                            <field name="price"/>

                            <field name="duration"
                                   placeholder="3-4 Hours"/>

                            <field name="age_limit"
                                   placeholder="10+ Years"/>

                            <field name="group_size"
                                   placeholder="2-4 People"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Description">

                            <field name="description"
                                   placeholder="Water sport description..."/>

                        </page>
                                                <page string="Gallery Images">

                            <field name="image_ids" mode="kanban">

                                <kanban>
                                    <field name="name"/>
                                    <field name="image"/>

                                    <templates>
                                        <t t-name="card">
                                            <div class="oe_kanban_global_click">

                                                <div class="text-center">
                                                    <field name="image" widget="image"/>
                                                </div>

                                                <div class="text-center mt-2">
                                                    <strong>
                                                        <field name="name"/>
                                                    </strong>
                                                </div>

                                            </div>
                                        </t>
                                    </templates>

                                </kanban>

                                <form>
                                    <sheet>

                                        <group>
                                            <field name="name"/>
                                        </group>

                                        <field name="image"
                                               widget="image"
                                        />

                                    </sheet>
                                </form>

                            </field>

                        </page>


                        <page string="Included Activities">

                            <field name="include_ids"
                                   widget="many2many_tags"/>

                        </page>

                        <page string="Bookings">

                            <field name="booking_ids">

                                <list>
                                    <field name="customer_id"/>
                                    <field name="booking_date"/>
                                    <field name="participants"/>
                                    <field name="state"/>
                                    <field name="booking_datetime"/>
                                </list>

                                <form>
                                    <sheet>
                                        <group>
                                            <field name="customer_id"/>

                                            <field name="booking_date"/>

                                            <field name="participants"/>

                                            <field name="description"/>

                                            <field name="state"/>

                                            <field name="booking_datetime"
                                                   readonly="1"/>
                                        </group>
                                    </sheet>
                                </form>

                            </field>

                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>


    <record id="view_water_sport_list" model="ir.ui.view">
        <field name="name">tour.water.sport.list</field>
        <field name="model">tour.water.sport</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="price"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_water_sport_kanban" model="ir.ui.view">
        <field name="name">tour.water.sport.kanban</field>
        <field name="model">tour.water.sport</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="name"/>
                <field name="image"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="price"/>

                <templates>
                    <t t-name="card" class="flex-row">

                        <aside class="o_kanban_aside_full">
                            <field name="image"
                                   widget="background_image"
                                   class="d-block position-relative"/>
                        </aside>

                        <main class="ms-2">

                            <div class="fw-bold fs-5">
                                <field name="name"/>
                            </div>

                            <div>
                                <i class="fa fa-map-marker me-2"/>
                                <field name="island_id"/>
                            </div>

                            <div>
                                <i class="fa fa-building me-2"/>
                                <field name="vendor_id"/>
                            </div>

                            <div>
                                <i class="fa fa-money me-2"/>
                                ₹
                                <field name="price"/>
                            </div>

                        </main>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="seq_water_sport_booking" model="ir.sequence">
        <field name="name">Water Sport Booking</field>
        <field name="code">tour.water.sport.booking</field>
        <field name="prefix">WSB/</field>
        <field name="padding">5</field>
    </record>

    <record id="action_water_sport" model="ir.actions.act_window">
        <field name="name">Water Sports</field>
        <field name="res_model">tour.water.sport</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_water_sport"
              name="Water Sports"
              action="action_water_sport"
              sequence="30"/>

</odoo>