<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vendor List -->

    <record id="view_tour_vendor_list" model="ir.ui.view">
        <field name="name">tour.vendor.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
            </list>
        </field>
    </record>

    <!-- Vendor Form -->

    <record id="view_tour_vendor_form" model="ir.ui.view">
        <field name="name">tour.vendor.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form>

                <sheet>

                    <group>

                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>

                        <group>
                            <field name="street"/>
                            <field name="street2"/>
                            <field name="city"/>
                            <field name="zip"/>
                            <field name="country_id"/>
                        </group>

                    </group>

                </sheet>

            </form>
        </field>
    </record>

    <!-- Vendor Action -->

    <record id="action_tour_vendors" model="ir.actions.act_window">
        <field name="name">Vendors</field>
        <field name="res_model">res.partner</field>
        <field name="domain">[('is_vendor','=',True)]</field>
        <field name="context">{'default_is_vendor': True}</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[
            (ref('view_tour_vendor_list'),'list'),
            (ref('view_tour_vendor_form'),'form')
        ]"/>
    </record>
     <menuitem id="menu_vendors"
              name="Vendors"
              parent="menu_lakshadweep_tourism"
              action="action_tour_vendors"
              sequence="50"/>


</odoo>