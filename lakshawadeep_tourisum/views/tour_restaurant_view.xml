<odoo>

    <!-- CUISINE -->

    <record id="view_tour_cuisine_list" model="ir.ui.view">
        <field name="name">tour.cuisine.list</field>
        <field name="model">tour.cuisine</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tour_cuisine_form" model="ir.ui.view">
        <field name="name">tour.cuisine.form</field>
        <field name="model">tour.cuisine</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tour_cuisine" model="ir.actions.act_window">
        <field name="name">Cuisines</field>
        <field name="res_model">tour.cuisine</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- RESTAURANT -->

    <record id="view_tour_restaurant_form" model="ir.ui.view">
        <field name="name">tour.restaurant.form</field>
        <field name="model">tour.restaurant</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="island_id"/>
                            <field name="vendor_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="image" widget="image"/>
                        </group>

                        <group>
                            <field name="cuisine_ids"
                                   widget="many2many_tags"/>
                            <field name="rating"/>
                            <field name="reviews"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <field name="description"/>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tour_restaurant_list" model="ir.ui.view">
        <field name="name">tour.restaurant.list</field>
        <field name="model">tour.restaurant</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="rating"/>
                <field name="reviews"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tour_restaurant_kanban" model="ir.ui.view">
        <field name="name">tour.restaurant.kanban</field>
        <field name="model">tour.restaurant</field>
        <field name="arch" type="xml">
            <kanban>

                <field name="name"/>
                <field name="image"/>
                <field name="rating"/>

                <templates>
                    <t t-name="card">

                        <div class="oe_kanban_global_click">

                            <field name="image"
                                   widget="image"
                                   class="oe_kanban_avatar"/>

                            <div class="mt-2">
                                <strong>
                                    <field name="name"/>
                                </strong>
                            </div>

                            <div>
                                Rating :
                                <field name="rating"/>
                            </div>

                        </div>

                    </t>
                </templates>

            </kanban>
        </field>
    </record>

    <record id="action_tour_restaurant" model="ir.actions.act_window">
        <field name="name">Restaurants</field>
        <field name="res_model">tour.restaurant</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- MENUS -->


    <menuitem id="menu_tour_restaurant"
              name="Restaurants"
              action="action_tour_restaurant"
              sequence="20"/>

</odoo>