<odoo>

    <!-- CUISINE -->

    <record id="view_tour_cuisine_list" model="ir.ui.view">
        <field name="name">tour.cuisine.list</field>
        <field name="model">tour.cuisine</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tour_cuisine_form" model="ir.ui.view">
        <field name="name">tour.cuisine.form</field>
        <field name="model">tour.cuisine</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tour_cuisine" model="ir.actions.act_window">
        <field name="name">Cuisines</field>
        <field name="res_model">tour.cuisine</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- RESTAURANT -->

    <record id="view_tour_restaurant_form" model="ir.ui.view">
        <field name="name">tour.restaurant.form</field>
        <field name="model">tour.restaurant</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <field name="image" widget="image" class="oe_avatar"/>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="island_id"/>

                            <field name="vendor_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>

                            <field name="phone"/>

                            <field name="active"/>
                        </group>

                        <group>
                            <field name="cuisine_ids" widget="many2many_tags"/>

                            <label for="opening_time" string="Opening Time"/>
                            <div>
                                <field name="opening_time" placeholder="07:00" class="oe_inline"/>
                                <field name="opening_period" class="oe_inline" />
                            </div>

                            <label for="closing_time" string="Closing Time"/>
                            <div>
                                <field name="closing_time" placeholder="10:30" class="oe_inline"/>
                                <field name="closing_period" class="oe_inline" />
                            </div>

                            <field name="opening_note" placeholder="Open Daily"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Description">
                            <field name="description"
                                   placeholder="Restaurant description..."/>
                        </page>

                        <page string="Location">
                            <group>
                                <field name="address"/>

                                <group>
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                </group>
                            </group>
                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>


    .
    <record id="view_tour_restaurant_list" model="ir.ui.view">
        <field name="name">tour.restaurant.list</field>
        <field name="model">tour.restaurant</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="island_id"/>
                <field name="vendor_id"/>

                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tour_restaurant_kanban" model="ir.ui.view">
        <field name="name">tour.restaurant.kanban</field>
        <field name="model">tour.restaurant</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="name"/>
                <field name="image"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="cuisine_ids"/>

                <templates>
                    <t t-name="card" class="flex-row">

                        <aside class="o_kanban_aside_full">
                            <field name="image"
                                   widget="background_image"
                                   class="d-block position-relative"/>
                        </aside>

                        <main class="ms-2">

                            <div class="fw-bold fs-5">
                                <field name="name"/>
                            </div>

                            <div>
                                <i class="fa fa-map-marker me-2"/>
                                <field name="island_id"/>
                            </div>

                            <div>
                                <i class="fa fa-building me-2"/>
                                <field name="vendor_id"/>
                            </div>

                            <div>
                                <i class="fa fa-cutlery me-2"/>
                                <field name="cuisine_ids"
                                       widget="many2many_tags"/>
                            </div>

                        </main>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <record id="action_tour_restaurant" model="ir.actions.act_window">
        <field name="name">Restaurants</field>
        <field name="res_model">tour.restaurant</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- MENUS -->


    <menuitem id="menu_tour_restaurant"
              name="Restaurants"
              action="action_tour_restaurant"
              sequence="20"/>

</odoo>