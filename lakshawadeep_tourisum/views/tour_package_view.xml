<odoo>

    <record id="view_package_form" model="ir.ui.view">
        <field name="name">tour.package.form</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <field name="image"
                           widget="image"
                           class="oe_avatar"/>

                    <group>
                        <group>
                            <field name="name"/>

                            <field name="island_id"/>

                            <field name="vendor_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>

                            <field name="active"/>
                        </group>

                        <group>
                            <field name="duration"
                                   placeholder="3 Nights / 4 Days"/>

                            <field name="price"/>

                            <field name="service_ids"
                                   widget="many2many_tags"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Description">

                            <field name="description"
                                   placeholder="Package description..."/>

                        </page>

                        <page string="Included Services">

                            <field name="service_ids"
                                   widget="many2many_tags"/>

                        </page>

                        <page string="Bookings">

                            <field name="booking_ids" readonly="1">

                                <list>
                                    <field name="booking_datetime"/>
                                    <field name="customer_id"/>
                                    <field name="description"/>

                                    <field name="travel_date"/>
                                    <field name="persons"/>
                                    <field name="state"/>

                                </list>

                                <form>
                                    <sheet>
                                        <group>
                                            <field name="booking_datetime"
                                                   readonly="1"/>
                                            <field name="customer_id"/>

                                            <field name="travel_date"/>

                                            <field name="persons"/>

                                            <field name="description"/>

                                            <field name="state"/>


                                        </group>
                                    </sheet>
                                </form>

                            </field>

                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>
    <record id="view_package_list" model="ir.ui.view">
        <field name="name">tour.package.list</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="duration"/>
                <field name="price"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_package_kanban" model="ir.ui.view">
        <field name="name">tour.package.kanban</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="name"/>
                <field name="image"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="duration"/>
                <field name="price"/>

                <templates>
                    <t t-name="card" class="flex-row">

                        <aside class="o_kanban_aside_full">
                            <field name="image"
                                   widget="background_image"
                                   class="d-block position-relative"/>
                        </aside>

                        <main class="ms-2">

                            <div class="fw-bold fs-5">
                                <field name="name"/>
                            </div>

                            <div>
                                <i class="fa fa-map-marker me-2"/>
                                <field name="island_id"/>
                            </div>

                            <div>
                                <i class="fa fa-building me-2"/>
                                <field name="vendor_id"/>
                            </div>

                            <div>
                                <i class="fa fa-clock-o me-2"/>
                                <field name="duration"/>
                            </div>

                            <div>
                                <i class="fa fa-money me-2"/>
                                ₹
                                <field name="price"/>
                            </div>

                        </main>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <record id="view_package_search" model="ir.ui.view">
        <field name="name">tour.package.search</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <search>

                <field name="name"/>
                <field name="island_id"/>
                <field name="vendor_id"/>

                <filter name="active_filter"
                        string="Active"
                        domain="[('active','=',True)]"/>

                 <filter name="agatti"
                            string="Agatti"
                            domain="[('island_id.name','=','Agatti')]"/>

                    <filter name="kavaratti"
                            string="Kavaratti"
                            domain="[('island_id.name','=','Kavaratti')]"/>

                    <filter name="kalpeni"
                            string="Kalpeni"
                            domain="[('island_id.name','=','Kalpeni')]"/>

                    <filter name="kadamath"
                            string="Kadamath"
                            domain="[('island_id.name','=','Kadamath')]"/>

                <group expand="0" string="Group By">

                    <filter name="group_island"
                            string="Island"
                            context="{'group_by':'island_id'}"/>

                    <filter name="group_vendor"
                            string="Vendor"
                            context="{'group_by':'vendor_id'}"/>

                </group>

            </search>
        </field>
    </record>


    <record id="action_package" model="ir.actions.act_window">
        <field name="name">Tour Packages</field>
        <field name="res_model">tour.package</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_package_search"/>

    </record>

    <menuitem id="menu_package"
              name="Tour Packages"
              action="action_package"
              sequence="70"/>

</odoo>