<odoo>

    <record id="view_tour_island_list" model="ir.ui.view">
        <field name="name">tour.island.list</field>
        <field name="model">tour.island</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tour_island_form" model="ir.ui.view">
        <field name="name">tour.island.form</field>
        <field name="model">tour.island</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>


                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>

                        <group>
                        </group>
                    </group>

                    <group>
                        <field name="description"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>


    <record id="view_tour_island_kanban" model="ir.ui.view">
        <field name="name">tour.island.kanban</field>
        <field name="model">tour.island</field>
        <field name="arch" type="xml">
            <kanban sample="1">

                <field name="name"/>
                <field name="image"/>
                <field name="code"/>
                <field name="active"/>

                <templates>
                    <t t-name="card" class="flex-row">

                        <aside class="o_kanban_aside_full">
                            <field name="image"
                                   widget="background_image"
                                   class="d-block position-relative"/>
                        </aside>

                        <main class="ms-2">

                            <div class="fw-bold fs-5">
                                <field name="name"/>
                            </div>

                            <div>
                                <i class="fa fa-hashtag me-2"
                                   title="Code"/>
                                <field name="code"/>
                            </div>

                            <div>
                                <i class="fa fa-check-circle me-2"
                                   title="Status"/>
                                <field name="active"/>
                            </div>

                        </main>

                    </t>
                </templates>

            </kanban>
        </field>
    </record>

    <record id="action_tour_island" model="ir.actions.act_window">
        <field name="name">Islands</field>
        <field name="res_model">tour.island</field>
        <field name="view_mode">kanban,list,form</field>
    </record>


    <menuitem id="menu_lakshadweep_tourism"
              name="Lakshadweep  Tourism"
              sequence="1"/>
    <menuitem id="menu_tour_island"
              name="Island"
              action="action_tour_island"
              parent="menu_lakshadweep_tourism"
              sequence="1"/>


</odoo>