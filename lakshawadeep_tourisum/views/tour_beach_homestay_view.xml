<odoo>

    <!-- FORM -->

    <record id="view_beach_homestay_form" model="ir.ui.view">
        <field name="name">tour.beach.homestay.form</field>
        <field name="model">tour.beach.homestay</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>


                    <group>
                        <group>
                            <field name="name"/>
                            <field name="island_id"/>
                            <field name="vendor_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                        </group>

                        <group>

                            <field name="price_per_night"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <field name="description"/>

                    <notebook>
                        <page string="Details">

                            <group>
                                <field name="checkin_time"/>
                                <field name="checkout_time"/>
                            </group>

                        </page>
                        <page string="Gallery Images">

                            <field name="image_ids" mode="kanban">

                                <kanban>
                                    <field name="name"/>
                                    <field name="image"/>

                                    <templates>
                                        <t t-name="card">
                                            <div class="oe_kanban_global_click">

                                                <div class="text-center">
                                                    <field name="image" widget="image"/>
                                                </div>

                                                <div class="text-center mt-2">
                                                    <strong>
                                                        <field name="name"/>
                                                    </strong>
                                                </div>

                                            </div>
                                        </t>
                                    </templates>

                                </kanban>

                                <form>
                                    <sheet>
                                        <group>
                                            <field name="name"/>
                                        </group>

                                        <field name="image" widget="image"/>
                                    </sheet>
                                </form>

                            </field>

                        </page>

                        <page string="Amenities">

                            <group>

                                <group>
                                    <field name="sea_view"/>
                                    <field name="beach_access"/>
                                    <field name="free_wifi"/>
                                    <field name="air_conditioning"/>
                                    <field name="restaurant"/>
                                </group>

                                <group>
                                    <field name="swimming_pool"/>
                                    <field name="free_breakfast"/>
                                    <field name="airport_transfer"/>
                                    <field name="room_service"/>
                                    <field name="family_rooms"/>
                                </group>

                            </group>

                        </page>

                        <page string="Bookings">

                            <field name="booking_ids" readonly="1">

                                <list>
                                    <field name="booking_datetime"/>

                                    <field name="customer_id"/>
                                    <field name="check_in_date"/>
                                    <field name="check_out_date"/>
                                    <field name="guests"/>
                                    <field name="rooms"/>
                                    <field name="description"/>
                                    <!--            <field name="amount"/>-->
                                    <field name="state"/>
                                </list>

                                <form>
                                    <sheet>

                                        <group>
                                            <field name="customer_id" readonly="1"/>
                                            <field name="check_in_date"/>
                                            <field name="check_out_date"/>
                                        </group>

                                        <group>
                                            <field name="guests"/>
                                            <field name="description"/>
                                            <field name="rooms"/>
                                            <!--                    <field name="amount"/>-->
                                            <field name="state"/>
                                        </group>

                                    </sheet>
                                </form>

                            </field>

                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST -->

    <record id="view_beach_homestay_list" model="ir.ui.view">
        <field name="name">tour.beach.homestay.list</field>
        <field name="model">tour.beach.homestay</field>
        <field name="arch" type="xml">
            <list>

                <field name="name"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="price_per_night"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- KANBAN -->

    <record id="view_beach_homestay_kanban" model="ir.ui.view">
        <field name="name">tour.beach.homestay.kanban</field>
        <field name="model">tour.beach.homestay</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="name"/>
                <field name="image"/>
                <field name="island_id"/>
                <field name="vendor_id"/>
                <field name="price_per_night"/>

                <templates>
                    <t t-name="card" class="flex-row">

                        <aside class="o_kanban_aside_full">
                            <field name="image"
                                   widget="background_image"
                                   class="d-block position-relative"/>
                        </aside>

                        <main class="ms-2">

                            <div class="fw-bold fs-5">
                                <field name="name"/>
                            </div>

                            <div>
                                <i class="fa fa-map-marker me-2"/>
                                <field name="island_id"/>
                            </div>

                            <div>
                                <i class="fa fa-building me-2"/>
                                <field name="vendor_id"/>
                            </div>

                            <div>
                                <i class="fa fa-money me-2"/>
                                ₹
                                <field name="price_per_night"/>
                                / Night
                            </div>

                        </main>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="seq_beach_homestay_booking" model="ir.sequence">
        <field name="name">Beach Homestay Booking</field>
        <field name="code">tour.beach.homestay.booking</field>
        <field name="prefix">BHB/</field>
        <field name="padding">5</field>
    </record>

    <!-- ACTION -->

    <record id="action_beach_homestay" model="ir.actions.act_window">
        <field name="name">Beach Homestays</field>
        <field name="res_model">tour.beach.homestay</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- MENU -->

    <menuitem id="menu_beach_homestay"
              name="Beach Homestays"
              action="action_beach_homestay"
              sequence="20"/>

</odoo>